  "spacing": {
    "section": { "mobile": "6rem", "desktop": "8rem", "tailwind": "py-24 lg:py-32" },
    "container": { "max_width": "1200px", "padding": "20px", "tailwind": "max-w-[1200px] mx-auto px-5" },
    "component": { "min": "2rem", "max": "4rem" },
    "element": { "min": "1rem", "max": "1.5rem" }
  },

  "hover_system": {
    "description": "6-component hover system for all interactive cards",
    "components": {
      "1_glow_orb": {
        "description": "Background glow orb that fades in from corner",
        "css": "absolute -top-20 -left-20 w-40 h-40 rounded-full blur-3xl",
        "gradient": "linear-gradient(135deg, rgba(254, 49, 132, 0.4), rgba(236, 114, 17, 0.3))",
        "transition": "opacity 0.7s, all 0.7s"
      },
      "2_text_brightness": {
        "description": "Text opacity increases on hover",
        "from": "text-white/50 or text-white/60",
        "to": "text-white/70 or text-white/80",
        "transition": "color 0.3s"
      },
      "3_icon_scale": {
        "description": "Icon scales up on hover",
        "transform": "group-hover:scale-110",
        "transition": "transform 0.5s"
      },
      "4_icon_glow": {
        "description": "Icon container gets glow shadow",
        "shadow": "0 0 30px rgba(254, 49, 132, 0.3)",
        "border": "border-pink-500/50",
        "transition": "box-shadow 0.5s, border-color 0.5s"
      },
      "5_bottom_accent": {
        "description": "Gradient accent line scales in from center at bottom",
        "gradient": "linear-gradient(90deg, #FE3184 0%, #FF6B35 50%, #ec7211 100%)",
        "height": "4px",
        "transform": "scale-x-0 to scale-x-100",
        "transition": "transform 0.5s, opacity 0.5s"
      },
      "6_border_glow": {
        "description": "Inset border + outer glow appears",
        "shadow": "inset 0 0 0 1px rgba(254, 49, 132, 0.3), 0 0 40px rgba(254, 49, 132, 0.15)",
        "transition": "all 0.5s"
      }
    },
    "transition_durations": {
      "fast": "300ms",
      "medium": "500ms",
      "slow": "700ms"
    }
  },

  "glow_colors": {
    "pink_light": "rgba(254, 49, 132, 0.3)",
    "pink_standard": "rgba(254, 49, 132, 0.4)",
    "pink_intense": "rgba(254, 49, 132, 0.5)",
    "orange_light": "rgba(236, 114, 17, 0.3)",

  "animations": {
    "reveal": { "keyframes": "translateY(40px) opacity(0) -> translateY(0) opacity(1)", "duration": "0.8s", "easing": "ease-out" },
    "fade_in": { "keyframes": "opacity(0) -> opacity(1)", "duration": "1s", "easing": "ease-out" },
    "float": { "keyframes": "translateY(0) -> translateY(-20px) -> translateY(0)", "duration": "6s", "easing": "ease-in-out", "iteration": "infinite" },
    "pulse_glow": { "keyframes": "box-shadow 20px/0.3 -> 50px/0.5 -> 20px/0.3", "duration": "2s", "easing": "ease-in-out", "iteration": "infinite" },
    "shimmer": { "keyframes": "background-position -200% -> 200%", "duration": "2s", "iteration": "infinite" },
    "glow_pulse": { "keyframes": "opacity 0.5 -> 0.8 -> 0.5", "duration": "3s", "iteration": "infinite" },
    "slide_up": { "keyframes": "translateY(30px) opacity(0) -> translateY(0) opacity(1)", "duration": "0.6s", "easing": "ease-out" }
